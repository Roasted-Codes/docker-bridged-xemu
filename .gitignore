.jenkins-external
.claude/
.env

# Large files - distributed separately
*.qcow2
*.qcow2_orig
*.iso
*.img

# Compiled shared libraries (built inside container)
*.so

# Runtime-generated container files (created by LinuxServer base image)
services/xemu/data/.cache/
services/xemu/data/.local/
services/xemu/data/.dbus/
services/xemu/data/.XDG/
services/xemu/data/.Xresources
services/xemu/data/.xsettingsd
services/xemu/data/.bash_history
services/xemu/data/.bashrc
services/xemu/data/.config/pulse/
services/xemu/data/.config/openbox/
services/xemu/data/.config/labwc/
services/xemu/data/.config/gtk-3.0/
services/xemu/data/.config/glib-2.0/
services/xemu/data/.config/xfce4/
services/xemu/data/ssl/
services/xemu/data/Desktop/

# XLink Kai runtime data (exclude user.sh hook script from ignore)
services/xlinkkai/*
!services/xlinkkai/user.sh

# Derived artifacts (raw data in database)
services/statsborg/history/*_memdump.txt
services/statsborg/history/*_pgcr_annotated.txt

# Backup files
*.bak
*.bak-*

# Generated download bundles
services/gateway/downloads/
