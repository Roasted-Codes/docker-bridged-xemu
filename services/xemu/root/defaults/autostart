#!/bin/bash

# -----------------------------------------------------------------------------
# Automation Script Launcher
# -----------------------------------------------------------------------------
# Launch passleader automation script in its own terminal window if enabled.
# Set PASSLEADER_ENABLED=true in .env to activate.
# This allows users to see the automation output and stop it with Ctrl+C.
if [ "${PASSLEADER_ENABLED}" = "true" ] && [ -f /config/emulator/passleader_v3.sh ]; then
    echo "Launching passleader automation script in separate terminal..."
    foot -e bash /config/emulator/passleader_v3.sh &
fi
# -----------------------------------------------------------------------------

# Run xemu with dual QMP:
#   - Unix socket for halo-scraper (shared volume at /run/qmp/)
#   - TCP for StatsBorg and remote tools (backward compatible)
# foot is the terminal provided by the base image's labwc/Wayland session
foot -e /opt/xemu/AppRun \
  -qmp unix:/run/qmp/qmp.sock,server,nowait \
  -qmp tcp:0.0.0.0:4444,server,nowait
